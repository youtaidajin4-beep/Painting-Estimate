# Supabase (https://supabase.com/dashboard)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# LINE Login OIDC provider id (configured in Supabase Auth > Providers > OIDC)
VITE_LINE_OIDC_PROVIDER=line

# Edge Function URL (same as Supabase URL + /functions/v1)
VITE_SUPABASE_FUNCTIONS_URL=https://your-project.supabase.co/functions/v1
